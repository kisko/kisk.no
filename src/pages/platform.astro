---
import Layout from '../layouts/Layout.astro';
import logoFull from '../../Images/KISK_logo_full.png';
---

<Layout
  title="Platform — kisk.no"
  description="Explore the areas that will grow under kisk.no: apps, tools, and selected updates."
>
  <main>
    <div class="shell">
      <header class="topbar">
        <a class="brand" href="/" aria-label="Back to KISK home">
          <img src={logoFull.src} width={logoFull.width} height={logoFull.height} alt="KISK.no" class="brand-lockup" />
        </a>

        <nav class="nav" aria-label="Primary">
          <a href="/">Home</a>
          <a href="/platform/">Platform</a>
        </nav>
      </header>

      <section class="intro">
        <p class="eyebrow">Platform overview</p>
        <h1>What will grow under KISK.</h1>
        <p class="lede">
          This page outlines the areas that will gradually expand across kisk.no,
          from applications to tools, ideas, and selected updates.
        </p>
      </section>

      <section class="platform" aria-label="Portal structure preview">
        <article class="platform-card platform-card-primary">
          <p class="card-label">What you will find here</p>
          <h2>A single place for the work that matters most.</h2>
          <ul class="pill-grid">
            <li>Apps</li>
            <li>Ideas</li>
            <li>Tools</li>
            <li>Case studies</li>
            <li>Selected updates</li>
          </ul>
        </article>

        <article class="platform-card" id="focus">
          <p class="card-label">About the site</p>
          <h2>Built to stay simple, useful, and easy to navigate.</h2>
          <p>
            The ambition is to create a calm and professional digital home that
            makes it easy to discover new work without noise or clutter.
          </p>
        </article>

        <article class="platform-card platform-card-updates">
          <p class="card-label">Updates</p>
          <h2>Track new additions as the platform expands.</h2>
          <p>
            New tools and experiments will be surfaced directly on
            kisk.no as they are published.
          </p>
          <a class="text-link" href="/">
            Go to homepage
          </a>
        </article>
      </section>
    </div>
  </main>

  <style>
    :global(:root) {
      --page-bg: #09111d;
      --panel: rgb(11 19 33 / 72%);
      --panel-strong: rgb(15 28 46 / 88%);
      --border: rgb(139 170 255 / 18%);
      --border-strong: rgb(116 211 255 / 36%);
      --text-strong: #edf6ff;
      --text-soft: #9bb1c9;
      --accent-cyan: #66e0ff;
    }

    main {
      min-height: 100svh;
      padding: 20px;
      background:
        radial-gradient(circle at top left, rgb(35 92 255 / 16%), transparent 26%),
        radial-gradient(circle at 82% 18%, rgb(66 222 255 / 12%), transparent 22%),
        linear-gradient(155deg, #07111d 0%, #0c1624 42%, #050911 100%);
      color: var(--text-strong);
      font-family: "Manrope", "Segoe UI", sans-serif;
    }

    .shell {
      width: min(1180px, 100%);
      margin: 0 auto;
      display: grid;
      gap: 20px;
      padding: 18px;
      border: 1px solid var(--border);
      border-radius: 32px;
      background: linear-gradient(180deg, rgb(9 16 28 / 0.82), rgb(8 13 22 / 0.7));
      box-shadow: 0 28px 100px rgb(0 0 0 / 28%);
      backdrop-filter: blur(16px);
    }

    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
    }

    .brand-lockup {
      display: block;
      width: auto;
      height: 34px;
      filter: saturate(1.05) contrast(1.04) drop-shadow(0 8px 18px rgb(41 140 255 / 0.22));
    }

    .nav {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      align-items: center;
    }

    .nav a {
      padding: 0.6rem 0.95rem;
      border: 1px solid var(--border);
      border-radius: 999px;
      color: var(--text-soft);
      font-size: 0.92rem;
      text-decoration: none;
    }

    .intro {
      max-width: 60rem;
    }

    .eyebrow {
      display: inline-flex;
      margin: 0 0 0.9rem;
      padding: 0.42rem 0.76rem;
      border: 1px solid var(--border);
      border-radius: 999px;
      background: rgb(10 17 31 / 72%);
      color: var(--accent-cyan);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    h1 {
      margin: 0;
      font-family: "Space Grotesk", "Manrope", sans-serif;
      font-size: clamp(2.5rem, 5vw, 4.2rem);
      line-height: 0.96;
      letter-spacing: -0.045em;
    }

    .lede {
      max-width: 42rem;
      margin: 1rem 0 0;
      color: var(--text-soft);
      font-size: clamp(1rem, 1.8vw, 1.12rem);
      line-height: 1.6;
    }

    .platform {
      display: grid;
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: 14px;
    }

    .platform-card {
      grid-column: span 4;
      padding: 18px;
      border: 1px solid var(--border);
      border-radius: 24px;
      background: linear-gradient(180deg, var(--panel), rgb(8 13 24 / 82%));
      box-shadow: 0 16px 40px rgb(0 0 0 / 14%);
      backdrop-filter: blur(16px);
    }

    .platform-card-primary {
      grid-column: span 6;
      background:
        radial-gradient(circle at top right, rgb(77 144 255 / 0.12), transparent 38%),
        linear-gradient(180deg, var(--panel-strong), rgb(8 13 24 / 90%));
    }

    .platform-card-updates {
      grid-column: span 6;
      border-color: rgb(111 197 255 / 26%);
    }

    .card-label {
      margin: 0 0 0.7rem;
      color: var(--accent-cyan);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    h2 {
      margin: 0 0 0.65rem;
      font-family: "Space Grotesk", "Manrope", sans-serif;
      font-size: clamp(1.08rem, 2vw, 1.45rem);
      line-height: 1.14;
      letter-spacing: -0.03em;
    }

    .platform-card p {
      margin: 0;
      color: var(--text-soft);
      font-size: 0.97rem;
      line-height: 1.55;
    }

    .pill-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
      margin: 1rem 0 0;
      padding: 0;
      list-style: none;
    }

    .pill-grid li {
      padding: 0.72rem 0.85rem;
      border: 1px solid rgb(111 197 255 / 14%);
      border-radius: 16px;
      background: rgb(255 255 255 / 0.025);
      color: var(--text-strong);
      font-size: 0.92rem;
      font-weight: 600;
    }

    .text-link {
      display: inline-flex;
      margin-top: 0.9rem;
      color: var(--text-strong);
      font-weight: 700;
      text-decoration: none;
    }

    @media (max-width: 980px) {
      .topbar {
        flex-direction: column;
        align-items: flex-start;
      }

      .platform-card,
      .platform-card-primary,
      .platform-card-updates {
        grid-column: span 12;
      }
    }

    @media (max-width: 640px) {
      main {
        padding: 12px;
      }

      .shell {
        padding: 14px;
        border-radius: 24px;
      }

      .nav,
      .nav a {
        width: 100%;
      }

      .pill-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</Layout>