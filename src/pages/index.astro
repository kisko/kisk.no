---
import Layout from '../layouts/Layout.astro';
import logoFull from '../../Images/KISK_logo_full.png';
import logoLockup from '../../Images/KISK_logo_lockup.png';
---

<Layout
  title="kisk.no — Kjell Inge Skjønberg"
  description="A launch arena for Kjell Inge Skjønberg's apps, writing, experiments, and future projects."
>
  <main>
    <div class="shell">
      <header class="topbar">
        <a class="brand" href="#home" aria-label="KISK home">
          <img
            src={logoLockup.src}
            width={logoLockup.width}
            height={logoLockup.height}
            alt="KISK.no"
            class="brand-lockup"
          />
        </a>

        <nav class="nav" aria-label="Primary">
          <a href="/articles/">Articles</a>
          <a href="/platform/">Platform</a>
          <a href="/platform/">Overview</a>
          <a href="https://www.linkedin.com/in/kisko/" target="_blank" rel="noreferrer">LinkedIn</a>
        </nav>
      </header>

      <section class="hero" id="home">
        <div class="hero-copy">
          <p class="eyebrow">Personal brand and projects</p>
          <h1>A modern home for projects, writing, and selected work.</h1>
          <p class="lede">
            Welcome to kisk.no. This is the public home of Kjell Inge
            Skjonberg, where new projects, articles, and digital work will be
            presented in one clear and curated place.
          </p>

          <div class="actions">
            <a class="button button-primary" href="https://www.linkedin.com/in/kisko/" target="_blank" rel="noreferrer">
              Visit LinkedIn
            </a>
            <a class="button button-secondary" href="/platform/">
              Explore the platform
            </a>
          </div>

          <div class="quick-links" aria-label="Explore KISK">
            <a href="/articles/">Browse article archive</a>
            <a href="/platform/">Apps, articles, and tools</a>
            <a href="https://www.linkedin.com/in/kisko/" target="_blank" rel="noreferrer">Follow updates on LinkedIn</a>
          </div>
        </div>

        <aside class="hero-side" aria-label="KISK visual identity and direction">
          <div class="logo-panel">
            <div class="logo-stage">
                <img
                  src={logoFull.src}
                  width={logoFull.width}
                  height={logoFull.height}
                  alt="KISK.no logo"
                  class="logo"
                />
            </div>
            <div class="logo-note">
              <p class="card-label">KISK.no</p>
              <p>
                A visual identity for a growing collection of digital work,
                ideas, and professional publishing.
              </p>
            </div>
          </div>
        </aside>
      </section>

    </div>
  </main>

  <style>
    :global(:root) {
      --page-bg: #09111d;
      --panel: rgb(11 19 33 / 72%);
      --panel-strong: rgb(15 28 46 / 88%);
      --border: rgb(139 170 255 / 18%);
      --border-strong: rgb(116 211 255 / 36%);
      --text-strong: #edf6ff;
      --text-soft: #9bb1c9;
      --accent-cyan: #66e0ff;
      --accent-blue: #3b82f6;
      --accent-deep: #1d4ed8;
    }

    main {
      min-height: 100svh;
      padding: 20px;
      background:
        radial-gradient(circle at top left, rgb(35 92 255 / 16%), transparent 26%),
        radial-gradient(circle at 82% 18%, rgb(66 222 255 / 12%), transparent 22%),
        linear-gradient(155deg, #07111d 0%, #0c1624 42%, #050911 100%);
      color: var(--text-strong);
      font-family: "Manrope", "Segoe UI", sans-serif;
    }

    main::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      background-image:
        linear-gradient(rgb(255 255 255 / 0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgb(255 255 255 / 0.03) 1px, transparent 1px);
      background-size: 84px 84px;
      mask-image: linear-gradient(180deg, rgb(0 0 0 / 0.4), transparent 92%);
    }

    .shell {
      width: min(1180px, 100%);
      min-height: calc(100svh - 40px);
      margin: 0 auto;
      display: grid;
      grid-template-rows: auto 1fr;
      gap: 18px;
      padding: 18px;
      border: 1px solid var(--border);
      border-radius: 32px;
      background: linear-gradient(180deg, rgb(9 16 28 / 0.82), rgb(8 13 22 / 0.7));
      box-shadow: 0 28px 100px rgb(0 0 0 / 28%);
      backdrop-filter: blur(16px);
      position: relative;
      z-index: 1;
    }

    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      padding-bottom: 4px;
    }

    .brand {
      display: inline-flex;
      align-items: center;
      color: var(--text-strong);
      text-decoration: none;
    }

    .brand-lockup {
      display: block;
      width: auto;
      height: 34px;
      filter: saturate(1.05) contrast(1.04) drop-shadow(0 8px 18px rgb(41 140 255 / 0.22));
    }

    .nav {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      align-items: center;
    }

    .nav a {
      padding: 0.6rem 0.95rem;
      border: 1px solid var(--border);
      border-radius: 999px;
      color: var(--text-soft);
      font-size: 0.92rem;
      text-decoration: none;
      transition: border-color 0.18s ease, color 0.18s ease, background 0.18s ease;
    }

    .nav a:hover {
      color: var(--text-strong);
      border-color: var(--border-strong);
      background: rgb(255 255 255 / 0.03);
      text-decoration: none;
    }

    .hero {
      display: grid;
      grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
      gap: 24px;
      align-items: center;
      min-height: 0;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      margin: 0 0 0.9rem;
      padding: 0.42rem 0.76rem;
      border: 1px solid var(--border);
      border-radius: 999px;
      background: rgb(10 17 31 / 72%);
      color: var(--accent-cyan);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    h1 {
      margin: 0;
      max-width: 10ch;
      font-family: "Space Grotesk", "Manrope", sans-serif;
      font-size: clamp(2.8rem, 5.4vw, 4.9rem);
      line-height: 0.94;
      letter-spacing: -0.045em;
      text-wrap: balance;
    }

    .lede {
      max-width: 36rem;
      margin: 1rem 0 0;
      color: var(--text-soft);
      font-size: clamp(1rem, 1.8vw, 1.14rem);
      line-height: 1.6;
      text-wrap: pretty;
    }

    .actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      align-items: center;
      margin-top: 1.5rem;
    }

    .quick-links {
      display: flex;
      flex-wrap: wrap;
      gap: 18px;
      margin-top: 1.2rem;
    }

    .quick-links a {
      color: var(--text-soft);
      font-size: 0.95rem;
      text-decoration: none;
      border-bottom: 1px solid rgb(111 197 255 / 18%);
      padding-bottom: 0.18rem;
      transition: color 0.18s ease, border-color 0.18s ease;
    }

    .quick-links a:hover {
      color: var(--text-strong);
      border-color: var(--border-strong);
      text-decoration: none;
    }

    .button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 48px;
      padding: 0.82rem 1.2rem;
      border-radius: 999px;
      border: 1px solid transparent;
      font-size: 0.94rem;
      font-weight: 700;
      letter-spacing: 0.01em;
      text-decoration: none;
      transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
    }

    .button-primary {
      color: #031321;
      background: linear-gradient(135deg, #6ee7ff 0%, #72a4ff 100%);
      box-shadow: 0 14px 30px rgb(41 140 255 / 26%);
    }

    .button-primary:hover {
      transform: translateY(-1px);
      box-shadow: 0 20px 36px rgb(41 140 255 / 32%);
    }

    .button-secondary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      color: var(--text-strong);
      background: rgb(9 17 30 / 0.82);
      border: 1px solid var(--border);
      box-shadow: inset 0 1px 0 rgb(255 255 255 / 0.04);
    }

    .button-secondary:hover {
      border-color: var(--border-strong);
      transform: translateY(-1px);
      text-decoration: none;
    }

    .hero-side {
      display: flex;
      align-items: stretch;
    }

    .logo-panel {
      width: 100%;
      display: grid;
      gap: 14px;
      padding: 18px;
      border: 1px solid var(--border-strong);
      border-radius: 28px;
      background:
        radial-gradient(circle at top right, rgb(87 215 255 / 0.08), transparent 40%),
        linear-gradient(180deg, rgb(8 16 30 / 0.78), rgb(6 11 20 / 0.64));
      box-shadow:
        inset 0 1px 0 rgb(255 255 255 / 0.06),
        0 24px 60px rgb(1 8 20 / 34%);
    }

    .logo-stage {
      display: grid;
      place-items: center;
      min-height: 220px;
      padding: 0;
      background: transparent;
    }

    .logo {
      display: block;
      width: min(100%, 420px);
      height: auto;
      filter:
        saturate(1.03)
        contrast(1.02)
        drop-shadow(0 18px 34px rgb(35 104 255 / 0.22));
    }

    .logo-note {
      padding: 4px 2px 0;
    }

    .logo-note p:last-child {
      margin-bottom: 0;
      color: var(--text-soft);
    }

    .card-label {
      margin: 0 0 0.7rem;
      color: var(--accent-cyan);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    h2 {
      margin: 0 0 0.65rem;
      font-family: "Space Grotesk", "Manrope", sans-serif;
      font-size: clamp(1.08rem, 2vw, 1.45rem);
      line-height: 1.14;
      letter-spacing: -0.03em;
    }

    @media (max-width: 980px) {
      .shell {
        min-height: auto;
      }

      .topbar {
        flex-direction: column;
        align-items: flex-start;
      }

      .hero {
        grid-template-columns: 1fr;
      }

      h1 {
        max-width: 11ch;
      }

      .hero-side {
        order: -1;
      }

    }

    @media (max-width: 640px) {
      main {
        padding: 12px;
      }

      .shell {
        padding: 14px;
        border-radius: 24px;
      }

      .logo-panel {
        border-radius: 24px;
      }

      .logo-stage {
        min-height: 180px;
      }

      .actions {
        align-items: stretch;
      }

      .button,
      .nav {
        width: 100%;
      }

      .nav a,
      .button {
        width: 100%;
      }

    }

    @media (max-height: 860px) and (min-width: 981px) {
      .shell {
        gap: 14px;
      }

      h1 {
        font-size: clamp(2.5rem, 4.6vw, 4.2rem);
      }

      .logo-stage {
        min-height: 220px;
      }

      .platform-card,
      .logo-panel {
        padding: 16px;
      }
    }
  </style>
</Layout>
