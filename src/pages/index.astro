---
import Layout from '../layouts/Layout.astro';
---

<Layout title="kisk.no — Kjell Inge Skjønberg">
  <main>
    <section class="hero">
      <p class="eyebrow">kisk.no</p>
      <h1>Hei, jeg er Kjell Inge.</h1>
      <p class="lede">
        Welcome to my little corner of the internet. This site is a work in
        progress — more soon.
      </p>
      <ul class="links">
        <li><a href="https://github.com/kisko" rel="me">GitHub</a></li>
      </ul>
    </section>
  </main>

  <style>
    main {
      max-width: 42rem;
      margin: 0 auto;
      padding: 6rem 1.5rem;
    }

    .eyebrow {
      margin: 0 0 0.5rem;
      font-size: 0.875rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--muted);
    }

    h1 {
      margin: 0 0 1rem;
      font-size: clamp(2rem, 5vw, 3rem);
      line-height: 1.1;
    }

    .lede {
      margin: 0 0 2rem;
      font-size: 1.125rem;
      color: var(--muted);
    }

    .links {
      margin: 0;
      padding: 0;
      list-style: none;
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .links a {
      display: inline-block;
      padding: 0.5rem 1rem;
      border: 1px solid var(--muted);
      border-radius: 0.5rem;
      transition: border-color 0.15s ease, color 0.15s ease;
    }

    .links a:hover {
      border-color: var(--accent);
      text-decoration: none;
    }
  </style>
</Layout>
