---
import Layout from '../layouts/Layout.astro';
---

<Layout title="kisk.no — Kjell Inge Skjønberg">
  <main>
    <section class="hero">
      <p class="eyebrow">kisk.no</p>
      <h1>Page under construction.</h1>
      <p class="lede">
        This page is under construction for the moment.
      </p>
    </section>
  </main>

  <style>
    main {
      max-width: 42rem;
      margin: 0 auto;
      padding: 6rem 1.5rem;
    }

    .eyebrow {
      margin: 0 0 0.5rem;
      font-size: 0.875rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--muted);
    }

    h1 {
      margin: 0 0 1rem;
      font-size: clamp(2rem, 5vw, 3rem);
      line-height: 1.1;
    }

    .lede {
      margin: 0 0 2rem;
      font-size: 1.125rem;
      color: var(--muted);
    }

  </style>
</Layout>
