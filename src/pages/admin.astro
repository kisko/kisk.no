---
// Admin page — served at /admin/
// Standalone client-side page. No Astro layout used.
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Admin — kisk.no</title>
  <style>
    :root {
      --bg: #070e1a;
      --shell: #0b1424;
      --card: #0f1d30;
      --border: rgb(139 170 255 / 18%);
      --border-focus: rgb(116 211 255 / 50%);
      --text: #edf6ff;
      --muted: #7a96b4;
      --cyan: #66e0ff;
      --red: #f87171;
      --green: #4ade80;
      --yellow: #fbbf24;
      --radius: 16px;
      font-family: "Segoe UI", system-ui, sans-serif;
      color-scheme: dark;
    }

    *, *::before, *::after { box-sizing: border-box; }
    body { margin: 0; background: var(--bg); color: var(--text); min-height: 100vh; }

    .topbar {
      position: sticky; top: 0; z-index: 10;
      display: flex; align-items: center; justify-content: space-between; gap: 16px;
      padding: 14px 24px;
      background: rgb(7 14 26 / 0.92); backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border);
    }
    .topbar h1 { margin: 0; font-size: 1.1rem; font-weight: 700; letter-spacing: -0.02em; }
    .topbar a { color: var(--cyan); font-size: 0.92rem; text-decoration: none; }
    .topbar a:hover { text-decoration: underline; }

    .status-badge {
      display: inline-flex; align-items: center; gap: 7px;
      padding: 0.38rem 0.78rem; border-radius: 999px; border: 1px solid var(--border);
      font-size: 0.8rem; font-weight: 600;
    }
    .status-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--muted); }
    .status-badge[data-status="connected"] .status-dot { background: var(--green); }
    .status-badge[data-status="saving"]    .status-dot { background: var(--yellow); }
    .status-badge[data-status="error"]     .status-dot { background: var(--red); }

    .page { max-width: 1060px; margin: 0 auto; padding: 28px 20px 60px; }

    .auth-panel {
      display: grid; gap: 16px; padding: 24px;
      border: 1px solid var(--border); border-radius: var(--radius);
      background: var(--shell); margin-bottom: 28px;
    }
    .auth-panel h2 { margin: 0; font-size: 1.15rem; }
    .auth-panel p { margin: 0; color: var(--muted); font-size: 0.95rem; line-height: 1.55; }
    .auth-row { display: grid; grid-template-columns: 1fr auto auto; gap: 10px; }

    input, select, textarea {
      width: 100%; padding: 0.62rem 0.9rem;
      background: rgb(255 255 255 / 0.04); border: 1px solid var(--border);
      border-radius: 10px; color: var(--text); font-size: 0.95rem; font-family: inherit; line-height: 1.4;
    }
    input:focus, select:focus, textarea:focus {
      outline: none; border-color: var(--border-focus); background: rgb(255 255 255 / 0.06);
    }
    input[type="password"] { font-family: monospace; letter-spacing: 0.08em; }
    textarea { resize: vertical; min-height: 72px; }
    select option { background: #0f1d30; }

    button {
      display: inline-flex; align-items: center; justify-content: center; gap: 7px;
      padding: 0.6rem 1.1rem; border: 1px solid transparent; border-radius: 10px;
      font-size: 0.95rem; font-weight: 700; font-family: inherit; cursor: pointer;
      white-space: nowrap; transition: opacity 0.15s ease, transform 0.12s ease;
    }
    button:active { transform: translateY(1px); }
    button:disabled { opacity: 0.45; cursor: not-allowed; }
    .btn-primary { background: linear-gradient(135deg, #6ee7ff, #72a4ff); color: #031321; }
    .btn-secondary { background: transparent; border-color: var(--border); color: var(--text); }
    .btn-secondary:hover { border-color: var(--border-focus); }
    .btn-danger { background: transparent; border-color: rgb(248 113 113 / 40%); color: var(--red); }
    .btn-save { background: linear-gradient(135deg, #4ade80, #22d3ee); color: #031321; }

    .toolbar {
      display: flex; flex-wrap: wrap; align-items: center;
      justify-content: space-between; gap: 12px; margin-bottom: 18px;
    }
    .toolbar-left { display: flex; gap: 10px; flex-wrap: wrap; }
    .toolbar h2 { margin: 0; font-size: 1.1rem; }

    .article-list { display: grid; gap: 12px; }

    .article-card {
      border: 1px solid var(--border); border-radius: var(--radius);
      background: var(--shell); overflow: hidden;
    }
    .article-card:focus-within { border-color: var(--border-focus); }

    .card-header {
      display: grid; grid-template-columns: auto 1fr auto; gap: 12px;
      align-items: center; padding: 14px 16px; cursor: pointer; user-select: none;
    }
    .card-header:hover { background: rgb(255 255 255 / 0.015); }

    .card-num {
      display: inline-grid; place-items: center; width: 26px; height: 26px;
      border-radius: 8px; background: rgb(102 224 255 / 0.12);
      color: var(--cyan); font-size: 0.78rem; font-weight: 700; flex: 0 0 auto;
    }
    .card-title {
      font-weight: 600; font-size: 0.98rem;
      overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .card-meta { display: flex; align-items: center; gap: 8px; flex: 0 0 auto; }
    .tag {
      padding: 0.28rem 0.62rem; border-radius: 999px; border: 1px solid var(--border);
      font-size: 0.74rem; font-weight: 700; color: var(--cyan); letter-spacing: 0.04em;
    }
    .link-indicator { width: 8px; height: 8px; border-radius: 50%; background: var(--muted); }
    .link-indicator[data-linked="true"]  { background: var(--green); }
    .link-indicator[data-linked="false"] { background: var(--red); }
    .chevron { transition: transform 0.18s ease; color: var(--muted); flex: 0 0 auto; }
    .article-card.expanded .chevron { transform: rotate(180deg); }

    .card-body { display: none; padding: 0 16px 16px; border-top: 1px solid var(--border); }
    .article-card.expanded .card-body { display: grid; gap: 12px; }

    label {
      display: grid; gap: 5px; font-size: 0.85rem; font-weight: 600;
      color: var(--muted); letter-spacing: 0.05em; text-transform: uppercase;
    }
    .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .field-hint { font-size: 0.8rem; color: var(--muted); font-weight: 400; text-transform: none; letter-spacing: 0; }

    .toast {
      position: fixed; bottom: 24px; right: 24px; z-index: 100; display: none;
      padding: 14px 20px; border-radius: 14px; border: 1px solid var(--border);
      background: var(--card); font-size: 0.95rem;
      box-shadow: 0 20px 50px rgb(0 0 0 / 40%); max-width: 380px;
    }
    .toast.show { display: block; animation: slideIn 0.22s ease; }
    .toast.success { border-color: rgb(74 222 128 / 28%); color: var(--green); }
    .toast.error   { border-color: rgb(248 113 113 / 28%); color: var(--red); }
    @keyframes slideIn {
      from { opacity: 0; transform: translateY(12px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .hidden { display: none !important; }
    .empty-state { padding: 32px; text-align: center; color: var(--muted); font-size: 0.95rem; }
  </style>
</head>
<body>

<header class="topbar">
  <h1>kisk.no — Admin</h1>
  <div style="display:flex;align-items:center;gap:14px;">
    <span class="status-badge" id="statusBadge" data-status="idle">
      <span class="status-dot"></span>
      <span id="statusText">Not connected</span>
    </span>
    <a href="/" target="_blank">← View site</a>
  </div>
</header>

<div class="page">

  <section class="auth-panel" id="authPanel">
    <h2>GitHub connection</h2>
    <p>
      Enter a GitHub Personal Access Token with <strong>repo</strong> scope to read and save
      articles directly to the repository. The token is never stored — it lives only in memory
      for this session.
    </p>
    <div class="auth-row">
      <input type="password" id="tokenInput" placeholder="ghp_xxxxxxxxxxxxxxxx" autocomplete="off" />
      <button class="btn-primary" id="connectBtn" onclick="connect()">Connect</button>
      <button class="btn-secondary hidden" id="disconnectBtn" onclick="disconnect()">Disconnect</button>
    </div>
    <p id="authError" class="hidden" style="color:var(--red);margin:0;font-size:0.9rem;"></p>
  </section>

  <div id="editor" class="hidden">
    <div class="toolbar">
      <div class="toolbar-left">
        <h2>Articles <span id="articleCount" style="color:var(--muted);font-weight:400;"></span></h2>
        <button class="btn-secondary" onclick="addArticle()">+ Add article</button>
      </div>
      <button class="btn-save" id="saveBtn" onclick="saveAll()">
        <svg width="15" height="15" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.2">
          <polyline points="17 3 9 15 3 9"/>
        </svg>
        Save to repo
      </button>
    </div>
    <div id="articleList" class="article-list"></div>
  </div>

</div>

<div class="toast" id="toast"></div>

<script is:inline>
  const REPO_OWNER = 'kisko';
  const REPO_NAME  = 'kisk.no';
  const DATA_PATH  = 'src/data/articles.ts';
  const BRANCH     = 'main';
  const CATEGORIES = [
    'AI','Communication','Digital Transformation','Energy / Innovation',
    'Leadership','Technology Strategy','Other',
  ];

  let token = '', fileSha = '', articles = [];

  async function connect() {
    const err = document.getElementById('authError');
    token = document.getElementById('tokenInput').value.trim();
    err.textContent = ''; err.classList.add('hidden');
    if (!token) { showAuthError('Please enter a token.'); return; }
    setStatus('saving', 'Connecting\u2026');
    try {
      await loadArticles();
      document.getElementById('authPanel').style.cssText = 'opacity:0.5;pointer-events:none';
      document.getElementById('connectBtn').classList.add('hidden');
      document.getElementById('disconnectBtn').classList.remove('hidden');
      document.getElementById('editor').classList.remove('hidden');
      setStatus('connected', 'Connected');
    } catch (e) {
      token = '';
      showAuthError('Connection failed: ' + e.message);
      setStatus('error', 'Error');
    }
  }

  function disconnect() {
    token = ''; fileSha = ''; articles = [];
    document.getElementById('authPanel').style.cssText = '';
    document.getElementById('connectBtn').classList.remove('hidden');
    document.getElementById('disconnectBtn').classList.add('hidden');
    document.getElementById('editor').classList.add('hidden');
    document.getElementById('tokenInput').value = '';
    setStatus('idle', 'Not connected');
  }

  function showAuthError(msg) {
    const err = document.getElementById('authError');
    err.textContent = msg; err.classList.remove('hidden');
  }

  async function ghFetch(path, opts = {}) {
    const r = await fetch('https://api.github.com' + path, {
      ...opts,
      headers: {
        Authorization: 'Bearer ' + token,
        Accept: 'application/vnd.github+json',
        'X-GitHub-Api-Version': '2022-11-28',
        'Content-Type': 'application/json',
        ...(opts.headers ?? {}),
      },
    });
    if (!r.ok) { const b = await r.json().catch(() => ({})); throw new Error(b.message ?? `HTTP ${r.status}`); }
    return r.json();
  }

  async function loadArticles() {
    const file = await ghFetch(`/repos/${REPO_OWNER}/${REPO_NAME}/contents/${DATA_PATH}?ref=${BRANCH}`);
    fileSha = file.sha;
    articles = parseTs(atob(file.content.replace(/\n/g, '')));
    renderList();
  }

  function parseTs(src) {
    const m = src.match(/articles:\s*Article\[\]\s*=\s*(\[[\s\S]*?\]);/);
    if (!m) return [];
    try {
      return JSON.parse(m[1]
        .replace(/\/\/[^\n]*/g, '')
        .replace(/,\s*([\]}])/g, '$1')
        .replace(/(\w+):/g, '"$1":')
        .replace(/'/g, '"')
        .replace(/"null"/g, 'null'));
    } catch { return []; }
  }

  function serializeTs(arr) {
    const items = arr.map(a => `  {\n` +
      `    title: ${JSON.stringify(a.title)},\n` +
      `    href: ${JSON.stringify(a.href ?? '')},\n` +
      `    teaser: ${JSON.stringify(a.teaser ?? '')},\n` +
      `    publishedAt: ${a.publishedAt ? JSON.stringify(a.publishedAt) : 'null'},\n` +
      `    category: ${JSON.stringify(a.category ?? '')},\n` +
      `    source: 'LinkedIn',\n` +
      `  }`).join(',\n');
    return `export type Article = {\n  title: string;\n  href: string;\n  publishedAt: string | null;\n  teaser: string;\n  category?: string;\n  source?: string;\n};\n\n// Update each \`href\` to the real LinkedIn article URL.\n// Add publishedAt in ISO format: "2025-03-15".\nexport const articles: Article[] = [\n${items},\n];\n`;
  }

  async function saveAll() {
    setStatus('saving', 'Saving\u2026');
    document.getElementById('saveBtn').disabled = true;
    collectFormValues();
    const content = btoa(unescape(encodeURIComponent(serializeTs(articles))));
    try {
      const res = await ghFetch(`/repos/${REPO_OWNER}/${REPO_NAME}/contents/${DATA_PATH}`, {
        method: 'PUT',
        body: JSON.stringify({ message: 'admin: update article data', content, sha: fileSha, branch: BRANCH }),
      });
      fileSha = res.content.sha;
      setStatus('connected', 'Saved \u2713');
      showToast('Saved \u2014 deployment will start automatically.', 'success');
    } catch (e) {
      setStatus('error', 'Save failed');
      showToast('Save failed: ' + e.message, 'error');
    } finally {
      document.getElementById('saveBtn').disabled = false;
    }
  }

  function setStatus(s, t) {
    document.getElementById('statusBadge').setAttribute('data-status', s);
    document.getElementById('statusText').textContent = t;
  }

  function showToast(msg, type = 'success') {
    const el = document.getElementById('toast');
    el.textContent = msg; el.className = 'toast show ' + type;
    setTimeout(() => { el.className = 'toast'; }, 3600);
  }

  function renderList() {
    const list = document.getElementById('articleList');
    document.getElementById('articleCount').textContent = `(${articles.length})`;
    list.innerHTML = '';
    if (!articles.length) {
      list.innerHTML = '<div class="empty-state">No articles yet. Click \u201c+ Add article\u201d to create one.</div>';
      return;
    }
    articles.forEach((a, i) => {
      const linked = a.href && a.href.startsWith('http');
      const catOpts = CATEGORIES.map(c => `<option value="${c}"${a.category === c ? ' selected' : ''}>${c}</option>`).join('');
      const el = document.createElement('div');
      el.className = 'article-card'; el.dataset.index = i;
      el.innerHTML = `
        <div class="card-header" onclick="toggleCard(${i})">
          <span class="card-num">${i + 1}</span>
          <span class="card-title">${esc(a.title) || '(untitled)'}</span>
          <div class="card-meta">
            ${a.category ? `<span class="tag">${esc(a.category)}</span>` : ''}
            <span class="link-indicator" data-linked="${linked}" title="${linked ? 'URL set' : 'Missing URL'}"></span>
            <svg class="chevron" width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2"><polyline points="2 4 7 10 12 4"/></svg>
          </div>
        </div>
        <div class="card-body">
          <label>TITLE<input type="text" data-field="title" data-index="${i}" value="${esc(a.title)}" placeholder="Article title" /></label>
          <label>LINKEDIN URL
            <input type="url" data-field="href" data-index="${i}" value="${esc(a.href)}" placeholder="https://www.linkedin.com/pulse/..." />
            <span class="field-hint">Paste the full LinkedIn article URL. Green dot = URL is set.</span>
          </label>
          <div class="field-row">
            <label>CATEGORY<select data-field="category" data-index="${i}">${catOpts}</select></label>
            <label>PUBLISHED DATE<input type="text" data-field="publishedAt" data-index="${i}" value="${esc(a.publishedAt)}" placeholder="2025-03-15 (optional)" /></label>
          </div>
          <label>TEASER<textarea data-field="teaser" data-index="${i}" placeholder="Short teaser text for the card">${esc(a.teaser)}</textarea></label>
          <div style="display:flex;gap:10px;justify-content:flex-end;">
            <button class="btn-danger" onclick="removeArticle(${i})">Remove</button>
          </div>
        </div>`;
      list.appendChild(el);
    });
  }

  function esc(v) {
    if (v == null) return '';
    return String(v).replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;');
  }

  function toggleCard(i) {
    document.querySelector(`.article-card[data-index="${i}"]`).classList.toggle('expanded');
  }

  function collectFormValues() {
    document.querySelectorAll('[data-field]').forEach(el => {
      const i = +el.dataset.index, f = el.dataset.field;
      const v = el.tagName === 'TEXTAREA' ? el.value : el.value.trim();
      articles[i][f] = (f === 'publishedAt' && !v) ? null : v;
    });
  }

  function addArticle() {
    collectFormValues();
    articles.unshift({ title:'', href:'', teaser:'', publishedAt:null, category:'AI', source:'LinkedIn' });
    renderList();
    const first = document.querySelector('.article-card');
    if (first) { first.classList.add('expanded'); first.querySelector('[data-field="title"]').focus(); }
  }

  function removeArticle(i) {
    if (!confirm('Remove this article?')) return;
    collectFormValues(); articles.splice(i, 1); renderList();
  }

  document.addEventListener('input', e => {
    const el = e.target, card = el.closest?.('.article-card');
    if (!card) return;
    if (el.dataset.field === 'href') {
      card.querySelector('.link-indicator')?.setAttribute('data-linked', String(el.value.startsWith('http')));
    }
    if (el.dataset.field === 'title') {
      const t = card.querySelector('.card-title');
      if (t) t.textContent = el.value || '(untitled)';
    }
  });

  document.getElementById('tokenInput').addEventListener('keydown', e => { if (e.key === 'Enter') connect(); });
</script>

</body>
</html>
