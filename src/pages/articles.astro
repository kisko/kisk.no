---
import Layout from '../layouts/Layout.astro';
import logoLockup from '../../Images/KISK_logo_lockup.png';
import { articles } from '../data/articles';

const articleCount = articles.length;
const latestArticle = articles[0];
---

<Layout
  title="Articles — kisk.no"
  description="A curated article archive for published writing from Kjell Inge Skjonberg."
>
  <main>
    <div class="shell">
      <header class="topbar">
        <a class="brand" href="/" aria-label="Back to KISK home">
          <img
            src={logoLockup.src}
            width={logoLockup.width}
            height={logoLockup.height}
            alt="KISK.no"
            class="brand-lockup"
          />
        </a>

        <nav class="nav" aria-label="Primary">
          <a href="/">Home</a>
          <a href="/platform/">Platform</a>
          <a href="https://www.linkedin.com/in/kisko/" target="_blank" rel="noreferrer">LinkedIn</a>
        </nav>
      </header>

      <section class="intro">
        <div class="intro-copy">
          <p class="eyebrow">Article archive</p>
          <h1>Writing collected into a cleaner reading experience.</h1>
          <p class="lede">
            This archive is designed to surface published writing in a calmer,
            more curated format than a social feed, while still linking each
            reader directly to the original article.
          </p>

          <div class="intro-actions">
            <a href="https://www.linkedin.com/in/kisko/" target="_blank" rel="noreferrer" class="button button-primary">
              View LinkedIn profile
            </a>
            <a href="/platform/" class="button button-secondary">
              Explore the platform
            </a>
          </div>
        </div>

        <aside class="summary-card" aria-label="Archive summary">
          <p class="card-label">Archive status</p>
          <div class="summary-metric">
            <strong>{articleCount}</strong>
            <span>article card{articleCount === 1 ? '' : 's'} in the archive</span>
          </div>
          <p class="summary-copy">
            The archive is live and ready to expand as more published writing is
            added.
          </p>
        </aside>
      </section>

      <section class="featured-strip" aria-label="Featured article overview">
        <article class="featured-card">
          <p class="card-label">Featured card</p>
          <h2>{latestArticle.title}</h2>
          <p>{latestArticle.teaser}</p>
          <a href={latestArticle.href} target="_blank" rel="noreferrer" class="text-link">
            Open article
          </a>
        </article>

        <article class="note-card">
          <p class="card-label">Reading experience</p>
          <h2>Made for browsing, not digging through a feed.</h2>
          <p>
            Each article gets its own teaser card here, so the archive can grow
            into a more useful and readable destination over time.
          </p>
        </article>
      </section>

      <section class="article-grid" aria-label="Published articles">
        {articles.map((article) => (
          <article class="article-card">
            <div class="article-meta">
              <span>{article.category ?? 'Article'}</span>
              {article.publishedAt && <span>{article.publishedAt}</span>}
            </div>
            <h2>{article.title}</h2>
            <p>{article.teaser}</p>
            <a href={article.href} target="_blank" rel="noreferrer" class="text-link">
              Read article
            </a>
          </article>
        ))}
      </section>
    </div>
  </main>

  <style>
    :global(:root) {
      --page-bg: #09111d;
      --panel: rgb(11 19 33 / 72%);
      --panel-strong: rgb(15 28 46 / 88%);
      --border: rgb(139 170 255 / 18%);
      --border-strong: rgb(116 211 255 / 36%);
      --text-strong: #edf6ff;
      --text-soft: #9bb1c9;
      --accent-cyan: #66e0ff;
    }

    main {
      min-height: 100svh;
      padding: 20px;
      background:
        radial-gradient(circle at top left, rgb(35 92 255 / 16%), transparent 26%),
        radial-gradient(circle at 82% 18%, rgb(66 222 255 / 12%), transparent 22%),
        linear-gradient(155deg, #07111d 0%, #0c1624 42%, #050911 100%);
      color: var(--text-strong);
      font-family: "Manrope", "Segoe UI", sans-serif;
    }

    .shell {
      width: min(1180px, 100%);
      margin: 0 auto;
      display: grid;
      gap: 22px;
      padding: 18px;
      border: 1px solid var(--border);
      border-radius: 32px;
      background: linear-gradient(180deg, rgb(9 16 28 / 0.82), rgb(8 13 22 / 0.7));
      box-shadow: 0 28px 100px rgb(0 0 0 / 28%);
      backdrop-filter: blur(16px);
    }

    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
    }

    .brand-lockup {
      display: block;
      width: auto;
      height: 34px;
      filter: saturate(1.05) contrast(1.04) drop-shadow(0 8px 18px rgb(41 140 255 / 0.22));
    }

    .nav {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      align-items: center;
    }

    .nav a {
      padding: 0.6rem 0.95rem;
      border: 1px solid var(--border);
      border-radius: 999px;
      color: var(--text-soft);
      font-size: 0.92rem;
      text-decoration: none;
    }

    .intro {
      display: grid;
      grid-template-columns: minmax(0, 1.15fr) minmax(280px, 0.85fr);
      gap: 18px;
      align-items: end;
    }

    .intro-copy {
      max-width: 60rem;
    }

    .eyebrow {
      display: inline-flex;
      margin: 0 0 0.9rem;
      padding: 0.42rem 0.76rem;
      border: 1px solid var(--border);
      border-radius: 999px;
      background: rgb(10 17 31 / 72%);
      color: var(--accent-cyan);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    h1 {
      margin: 0;
      font-family: "Space Grotesk", "Manrope", sans-serif;
      font-size: clamp(2.5rem, 5vw, 4rem);
      line-height: 0.98;
      letter-spacing: -0.045em;
      max-width: 12ch;
    }

    .lede {
      max-width: 44rem;
      margin: 1rem 0 0;
      color: var(--text-soft);
      font-size: clamp(1rem, 1.8vw, 1.12rem);
      line-height: 1.6;
    }

    .intro-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 1.4rem;
    }

    .button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 46px;
      padding: 0.78rem 1.15rem;
      border-radius: 999px;
      border: 1px solid transparent;
      font-size: 0.94rem;
      font-weight: 700;
      text-decoration: none;
    }

    .button-primary {
      color: #031321;
      background: linear-gradient(135deg, #6ee7ff 0%, #72a4ff 100%);
      box-shadow: 0 14px 30px rgb(41 140 255 / 26%);
    }

    .button-secondary {
      color: var(--text-strong);
      background: rgb(9 17 30 / 0.82);
      border-color: var(--border);
      box-shadow: inset 0 1px 0 rgb(255 255 255 / 0.04);
    }

    .summary-card,
    .featured-card,
    .note-card,
    .article-card {
      border: 1px solid var(--border);
      border-radius: 24px;
      background:
        radial-gradient(circle at top right, rgb(77 144 255 / 0.1), transparent 34%),
        linear-gradient(180deg, var(--panel-strong), rgb(8 13 24 / 86%));
      box-shadow: 0 16px 40px rgb(0 0 0 / 14%);
      backdrop-filter: blur(16px);
    }

    .summary-card {
      padding: 20px;
    }

    .summary-metric {
      display: grid;
      gap: 2px;
      margin-top: 0.35rem;
    }

    .summary-metric strong {
      font-family: "Space Grotesk", "Manrope", sans-serif;
      font-size: clamp(2rem, 5vw, 3.4rem);
      line-height: 0.95;
      letter-spacing: -0.05em;
    }

    .summary-metric span,
    .summary-copy {
      color: var(--text-soft);
    }

    .summary-copy {
      margin: 0.9rem 0 0;
      font-size: 0.96rem;
      line-height: 1.55;
    }

    .featured-strip {
      display: grid;
      grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
      gap: 16px;
    }

    .featured-card,
    .note-card {
      padding: 20px;
    }

    .featured-card p,
    .note-card p {
      margin: 0;
      color: var(--text-soft);
      font-size: 0.98rem;
      line-height: 1.6;
    }

    .article-grid {
      display: grid;
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: 16px;
    }

    .article-card {
      grid-column: span 4;
      display: grid;
      gap: 12px;
      padding: 22px;
    }

    .article-meta {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      color: var(--accent-cyan);
      font-size: 0.76rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    h2 {
      margin: 0;
      font-family: "Space Grotesk", "Manrope", sans-serif;
      font-size: clamp(1.1rem, 2vw, 1.4rem);
      line-height: 1.16;
      letter-spacing: -0.03em;
    }

    .article-card p {
      margin: 0;
      color: var(--text-soft);
      font-size: 0.98rem;
      line-height: 1.62;
    }

    .text-link {
      display: inline-flex;
      align-items: center;
      width: fit-content;
      color: var(--text-strong);
      font-weight: 700;
      text-decoration: none;
      border-bottom: 1px solid rgb(111 197 255 / 18%);
      padding-bottom: 0.18rem;
    }

    @media (max-width: 980px) {
      .topbar {
        flex-direction: column;
        align-items: flex-start;
      }

      .intro,
      .featured-strip {
        grid-template-columns: 1fr;
      }

      .article-card {
        grid-column: span 6;
      }
    }

    @media (max-width: 640px) {
      main {
        padding: 12px;
      }

      .shell {
        padding: 14px;
        border-radius: 24px;
      }

      .nav,
      .nav a {
        width: 100%;
      }

      .intro-actions {
        align-items: stretch;
      }

      .button {
        width: 100%;
      }

      .article-card {
        grid-column: span 12;
      }

      .article-meta {
        flex-direction: column;
        gap: 6px;
      }
    }
  </style>
</Layout>