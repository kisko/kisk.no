---
import Layout from '../layouts/Layout.astro';
import logoFull from '../../Images/KISK_logo_full.png';
import articlesData from '../data/articles.json';

const articles = [...articlesData].sort((a, b) => b.date.localeCompare(a.date));

const dateFmt = new Intl.DateTimeFormat('en-GB', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
const formatDate = (iso: string) => dateFmt.format(new Date(iso));
---

<Layout
  title="Articles - kisk.no"
  description="Articles and writing by Kjell Inge Skjonberg, published on LinkedIn and collected here."
>
  <main>
    <div class="shell">
      <header class="topbar">
        <a class="brand" href="/" aria-label="Back to KISK home">
          <img src={logoFull.src} width={logoFull.width} height={logoFull.height} alt="KISK.no" class="brand-lockup" />
        </a>

        <nav class="nav" aria-label="Primary">
          <a href="/">Home</a>
          <a href="/platform/">Platform</a>
          <a href="/articles/" aria-current="page">Articles</a>
        </nav>
      </header>

      <section class="intro">
        <p class="eyebrow">Writing</p>
        <h1>Articles</h1>
        <p class="lede">
          A collected index of articles published on LinkedIn. Each links straight
          to the original post.
        </p>
      </section>

      <section class="articles-region" aria-label="Published articles">
        <ul class="article-list">
          {articles.map((article) => (
            <li class="article-card">
              <a class="article-link" href={article.url} target="_blank" rel="noopener noreferrer">
                <div class="article-layout">
                  {article.image && (
                    <img
                      class="article-image"
                      src={article.image}
                      alt={article.title}
                      loading="lazy"
                      decoding="async"
                    />
                  )}
                  <div class="article-content">
                    <div class="article-head">
                      <h2>{article.title}</h2>
                      <time class="article-date" datetime={article.date}>{formatDate(article.date)}</time>
                    </div>
                    {article.summary && <p class="article-summary">{article.summary}</p>}
                    <span class="text-link">Read on LinkedIn -></span>
                  </div>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </section>
    </div>
  </main>

  <style>
    :global(:root) {
      --page-bg: #09111d;
      --panel: rgb(11 19 33 / 72%);
      --panel-strong: rgb(15 28 46 / 88%);
      --border: rgb(139 170 255 / 18%);
      --border-strong: rgb(116 211 255 / 36%);
      --text-strong: #edf6ff;
      --text-soft: #9bb1c9;
      --accent-cyan: #66e0ff;
    }

    main {
      height: 100svh;
      padding: 20px;
      overflow: hidden;
      background:
        radial-gradient(circle at top left, rgb(35 92 255 / 16%), transparent 26%),
        radial-gradient(circle at 82% 18%, rgb(66 222 255 / 12%), transparent 22%),
        linear-gradient(155deg, #07111d 0%, #0c1624 42%, #050911 100%);
      color: var(--text-strong);
      font-family: "Manrope", "Segoe UI", sans-serif;
    }

    .shell {
      width: min(1180px, 100%);
      height: calc(100svh - 40px);
      margin: 0 auto;
      display: grid;
      grid-template-rows: auto auto 1fr;
      gap: 18px;
      padding: 18px;
      border: 1px solid var(--border);
      border-radius: 32px;
      background: linear-gradient(180deg, rgb(9 16 28 / 0.82), rgb(8 13 22 / 0.7));
      box-shadow: 0 28px 100px rgb(0 0 0 / 28%);
      backdrop-filter: blur(16px);
      overflow: hidden;
    }

    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
    }

    .brand {
      display: inline-flex;
      align-items: center;
    }

    .brand-lockup {
      display: block;
      width: auto;
      height: 34px;
      filter: saturate(1.05) contrast(1.04) drop-shadow(0 8px 18px rgb(41 140 255 / 0.22));
    }

    .nav {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      align-items: center;
    }

    .nav a {
      padding: 0.6rem 0.95rem;
      border: 1px solid var(--border);
      border-radius: 999px;
      color: var(--text-soft);
      font-size: 0.92rem;
      text-decoration: none;
      transition: border-color 0.18s ease, color 0.18s ease, background 0.18s ease;
    }

    .nav a:hover {
      color: var(--text-strong);
      border-color: var(--border-strong);
      background: rgb(255 255 255 / 0.03);
      text-decoration: none;
    }

    .nav a[aria-current="page"] {
      color: var(--text-strong);
      border-color: var(--border-strong);
    }

    .intro {
      max-width: 60rem;
    }

    .eyebrow {
      display: inline-flex;
      margin: 0 0 0.7rem;
      padding: 0.42rem 0.76rem;
      border: 1px solid var(--border);
      border-radius: 999px;
      background: rgb(10 17 31 / 72%);
      color: var(--accent-cyan);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    h1 {
      margin: 0;
      font-family: "Space Grotesk", "Manrope", sans-serif;
      font-size: clamp(2.2rem, 4.4vw, 3.4rem);
      line-height: 0.96;
      letter-spacing: -0.045em;
    }

    .lede {
      max-width: 42rem;
      margin: 0.7rem 0 0;
      color: var(--text-soft);
      font-size: clamp(1rem, 1.8vw, 1.1rem);
      line-height: 1.55;
    }

    .articles-region {
      min-height: 0;
      overflow-y: auto;
      padding-right: 6px;
      scrollbar-width: thin;
      scrollbar-color: var(--border-strong) transparent;
    }

    .articles-region::-webkit-scrollbar {
      width: 8px;
    }

    .articles-region::-webkit-scrollbar-thumb {
      background: var(--border-strong);
      border-radius: 999px;
    }

    .article-list {
      display: grid;
      gap: 12px;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .article-card {
      border: 1px solid var(--border);
      border-radius: 24px;
      background: linear-gradient(180deg, var(--panel), rgb(8 13 24 / 82%));
      box-shadow: 0 16px 40px rgb(0 0 0 / 14%);
      transition: border-color 0.18s ease, transform 0.18s ease, box-shadow 0.18s ease;
    }

    .article-card:hover {
      border-color: var(--border-strong);
      transform: translateY(-1px);
      box-shadow: 0 22px 48px rgb(0 0 0 / 22%);
    }

    .article-link {
      display: block;
      padding: 18px;
      color: inherit;
      text-decoration: none;
    }

    .article-link:hover {
      text-decoration: none;
    }

    .article-layout {
      display: grid;
      grid-template-columns: 168px minmax(0, 1fr);
      gap: 14px;
      align-items: start;
    }

    .article-image {
      width: 168px;
      aspect-ratio: 16 / 9;
      object-fit: cover;
      border-radius: 12px;
      border: 1px solid var(--border);
      background: rgb(255 255 255 / 0.03);
      display: block;
    }

    .article-content {
      min-width: 0;
    }

    .article-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 16px;
    }

    h2 {
      margin: 0;
      font-family: "Space Grotesk", "Manrope", sans-serif;
      font-size: clamp(1.05rem, 2vw, 1.35rem);
      line-height: 1.18;
      letter-spacing: -0.03em;
      color: var(--text-strong);
    }

    .article-date {
      flex-shrink: 0;
      color: var(--accent-cyan);
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      white-space: nowrap;
    }

    .article-summary {
      margin: 0.55rem 0 0;
      color: var(--text-soft);
      font-size: 0.97rem;
      line-height: 1.55;
    }

    .text-link {
      display: inline-flex;
      margin-top: 0.8rem;
      color: var(--text-strong);
      font-weight: 700;
      font-size: 0.92rem;
    }

    @media (max-width: 980px) {
      .topbar {
        flex-direction: column;
        align-items: flex-start;
      }
    }

    @media (max-width: 640px) {
      main {
        padding: 12px;
      }

      .shell {
        height: calc(100svh - 24px);
        padding: 14px;
        border-radius: 24px;
      }

      .nav,
      .nav a {
        width: 100%;
      }

      .article-head {
        flex-direction: column;
        gap: 4px;
      }

      .article-layout {
        grid-template-columns: 1fr;
      }

      .article-image {
        width: 100%;
      }
    }
  </style>
</Layout>
